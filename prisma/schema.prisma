// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  CLIENT
  PROFESSIONAL
  ADMIN
}

enum AppointmentStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  COMPLETED
}

enum ServiceMode {
  ONLINE
  IN_PERSON
}

enum Status {
  ACTIVE
  INACTIVE
}

model User {
  id       Int    @id @default(autoincrement())
  name     String @db.VarChar(120)
  email    String @unique @db.VarChar(150)
  password String @db.VarChar(255)
  role     Role   @default(CLIENT)
  status   Status @default(ACTIVE)

  services                 Service[]     @relation("ProfessionalServices")
  clientAppointments       Appointment[] @relation("ClientAppointments")
  professionalAppointments Appointment[] @relation("ProfessionalAppointments")
  Clientreviews            Review[]      @relation("ClientReviews")
  professionalReviews      Review[]      @relation("ProfessionalReviews")

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @default(now()) @updatedAt
  professionalProfile ProfessionalProfile?
}

model Category {
  id          Int     @id @default(autoincrement())
  name        String  @unique @db.VarChar(100)
  description String? @db.VarChar(255)
  status      Status  @default(ACTIVE)

  services Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Specialty {
  id          Int     @id @default(autoincrement())
  name        String  @unique @db.VarChar(100)
  description String? @db.VarChar(255)
  status      Status  @default(ACTIVE)

  services Service[] @relation("ServiceSpecialties")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model ProfessionalProfile {
  id              Int         @id @default(autoincrement())
  userId          Int         @unique
  title           String      @unique @db.VarChar(100)
  description     String?     @db.VarChar(500)
  yearsExperience Int
  phone           String      @unique @db.VarChar(50)
  location        String      @db.VarChar(50)
  baseRate        Float
  mode            ServiceMode
  isAvailable     Boolean     @default(true)
  profileImage    String      @default("image-not-found.jpg") @db.VarChar(255)

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Service {
  id          Int         @id @default(autoincrement())
  name        String      @unique @db.VarChar(100)
  description String?     @db.VarChar(255)
  price       Float
  duration    Int
  mode        ServiceMode
  status      Status      @default(ACTIVE)

  professionalId Int
  categoryId     Int

  professional User        @relation("ProfessionalServices", fields: [professionalId], references: [id])
  category     Category    @relation(fields: [categoryId], references: [id])
  specialties  Specialty[] @relation("ServiceSpecialties")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  appointments Appointment[]
}

model Appointment {
  id          Int               @id @default(autoincrement())
  date        DateTime
  startTime   DateTime
  endTime     DateTime
  mode        ServiceMode
  description String?           @db.VarChar(255)
  status      AppointmentStatus @default(PENDING)

  clientId       Int
  professionalId Int
  serviceId      Int

  client       User    @relation("ClientAppointments", fields: [clientId], references: [id])
  professional User    @relation("ProfessionalAppointments", fields: [professionalId], references: [id])
  service      Service @relation(fields: [serviceId], references: [id])
  review       Review?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Review {
  id             Int @id @default(autoincrement())
  clientId       Int
  professionalId Int
  appointmentId  Int @unique

  rating  Int //1 to 5
  comment String? @db.VarChar(255)

  client       User        @relation("ClientReviews", fields: [clientId], references: [id])
  professional User        @relation("ProfessionalReviews", fields: [professionalId], references: [id])
  appointment  Appointment @relation(fields: [appointmentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}
